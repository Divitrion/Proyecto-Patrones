        <mxCell id="JqRvlmmjvBWTHTZVIOXe-15" parent="1" style="shape=note2;boundedLbl=1;whiteSpace=wrap;html=1;size=25;verticalAlign=top;align=left;spacingLeft=5;fontSize=12;" value="RETORNAR (armaInterna.CalcularDano() * (1 + multiplicadorFilo))" vertex="1">
          <mxGeometry height="60" width="410" x="390" y="1120" as="geometry" />
