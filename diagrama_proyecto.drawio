        <mxCell id="JqRvlmmjvBWTHTZVIOXe-17" parent="1" style="shape=note2;boundedLbl=1;whiteSpace=wrap;html=1;size=25;verticalAlign=top;align=left;spacingLeft=5;fontSize=12;" value="RETORNAR (armaInterna.CalcularDano() + bonusVeneno)" vertex="1">
