        <mxCell id="n6y0AcJ8ikb9XLiwta1j-28" parent="1" style="shape=note2;boundedLbl=1;whiteSpace=wrap;html=1;size=25;verticalAlign=top;align=left;spacingLeft=5;fontSize=12;" value="ESCRIBIR(&quot;{p.GetNombre()} está muerto y no puede usar habilidades.&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&quot;)&lt;/span&gt;" vertex="1">
          <mxGeometry height="60" width="440" x="1160" y="400" as="geometry" />
        </mxCell>
        <mxCell id="n6y0AcJ8ikb9XLiwta1j-29" parent="1" style="shape=note2;boundedLbl=1;whiteSpace=wrap;html=1;size=25;verticalAlign=top;align=left;spacingLeft=5;fontSize=12;" value="ESCRIBIR(&quot;{p.GetNombre()} está muerto y no puede defenderse.&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&quot;)&lt;/span&gt;" vertex="1">
          <mxGeometry height="60" width="440" x="1160" y="500" as="geometry" />
        </mxCell>
        <mxCell id="n6y0AcJ8ikb9XLiwta1j-30" parent="1" style="shape=note2;boundedLbl=1;whiteSpace=wrap;html=1;size=25;verticalAlign=top;align=left;spacingLeft=5;fontSize=12;" value="ESCRIBIR(&quot;{p.GetNombre()} está muerto y no puede atacar.&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&quot;)&lt;/span&gt;" vertex="1">
          <mxGeometry height="60" width="440" x="1160" y="600" as="geometry" />
        </mxCell>
        <mxCell id="n6y0AcJ8ikb9XLiwta1j-49" parent="1" style="shape=note2;boundedLbl=1;whiteSpace=wrap;html=1;size=25;verticalAlign=top;align=left;spacingLeft=5;fontSize=12;" value="ESCRIBIR(&quot;{p.GetNombre()} ataca con plena efectividad.&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&quot;)&lt;/span&gt;" vertex="1">
          <mxGeometry height="60" width="440" x="-690" y="102" as="geometry" />
        </mxCell>
        <mxCell id="n6y0AcJ8ikb9XLiwta1j-50" parent="1" style="shape=note2;boundedLbl=1;whiteSpace=wrap;html=1;size=25;verticalAlign=top;align=left;spacingLeft=5;fontSize=12;" value="ESCRIBIR(&quot;{p.GetNombre()} está saludable.&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&quot;)&lt;/span&gt;" vertex="1">
          <mxGeometry height="60" width="440" x="-690" y="2" as="geometry" />
        </mxCell>
        <mxCell id="n6y0AcJ8ikb9XLiwta1j-51" parent="1" style="shape=note2;boundedLbl=1;whiteSpace=wrap;html=1;size=25;verticalAlign=top;align=left;spacingLeft=5;fontSize=12;" value="ESCRIBIR(&quot;{p.GetNombre()} usa su habilidad con plena efectividad.&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&quot;)&lt;/span&gt;" vertex="1">
          <mxGeometry height="60" width="440" x="-690" y="302" as="geometry" />
        </mxCell>
        <mxCell id="n6y0AcJ8ikb9XLiwta1j-52" parent="1" style="shape=note2;boundedLbl=1;whiteSpace=wrap;html=1;size=25;verticalAlign=top;align=left;spacingLeft=5;fontSize=12;" value="ESCRIBIR(&quot;{p.GetNombre()} se defiende con plena efectividad.&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&quot;)&lt;/span&gt;" vertex="1">
          <mxGeometry height="60" width="440" x="-690" y="202" as="geometry" />
        </mxCell>
        <mxCell id="n6y0AcJ8ikb9XLiwta1j-54" parent="1" style="shape=note2;boundedLbl=1;whiteSpace=wrap;html=1;size=25;verticalAlign=top;align=left;spacingLeft=5;fontSize=12;" value="ESCRIBIR(&quot;{p.GetNombre()} ataca debilitado por el veneno.&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&quot;)&lt;/span&gt;" vertex="1">
          <mxGeometry height="60" width="440" x="-240" y="610" as="geometry" />
        </mxCell>
        <mxCell id="n6y0AcJ8ikb9XLiwta1j-55" parent="1" style="shape=note2;boundedLbl=1;whiteSpace=wrap;html=1;size=25;verticalAlign=top;align=left;spacingLeft=5;fontSize=12;" value="int dano = p.GetVida() * PorcentajeDanoPorTurno&lt;div&gt;ESCRIBIR(&quot;{p.GetNombre()} está envenenado. Pierde {dano} HP antes de actuar.&quot;)&lt;/div&gt;&lt;div&gt;p.RecibirDaño(dano)&lt;/div&gt;&lt;div&gt;p.DecrementarContadorVeneno()&lt;/div&gt;&lt;div&gt;SI (p.GetContadorVeneno() &amp;lt;= 0)&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;ESCRIBIR(&quot;{p.Nombre} se ha recuperado del veneno.&quot;)&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;p.CambiarEstado(EstadoSaludable.ObtenerInstancia())&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;p.ResetearContadorVeneno()&lt;/div&gt;&lt;div&gt;FIN SI&lt;/div&gt;" vertex="1">
          <mxGeometry height="170" width="480" x="-280" y="400" as="geometry" />
        </mxCell>
        <mxCell id="n6y0AcJ8ikb9XLiwta1j-56" parent="1" style="shape=note2;boundedLbl=1;whiteSpace=wrap;html=1;size=25;verticalAlign=top;align=left;spacingLeft=5;fontSize=12;" value="ESCRIBIR(&quot;{p.GetNombre()} usa su habilidad debilitado por el veneno.&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&quot;)&lt;/span&gt;" vertex="1">
          <mxGeometry height="60" width="440" x="-240" y="810" as="geometry" />
        </mxCell>
        <mxCell id="n6y0AcJ8ikb9XLiwta1j-57" parent="1" style="shape=note2;boundedLbl=1;whiteSpace=wrap;html=1;size=25;verticalAlign=top;align=left;spacingLeft=5;fontSize=12;" value="ESCRIBIR(&quot;{p.GetNombre()} se defiende debilitado por el veneno.&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&quot;)&lt;/span&gt;" vertex="1">
          <mxGeometry height="60" width="440" x="-240" y="710" as="geometry" />
        </mxCell>
        <mxCell id="n6y0AcJ8ikb9XLiwta1j-58" parent="1" style="shape=note2;boundedLbl=1;whiteSpace=wrap;html=1;size=25;verticalAlign=top;align=left;spacingLeft=5;fontSize=12;" value="ESCRIBIR(&quot;{p.GetNombre()} intenta atacar, pero está paralizado.&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&quot;)&lt;/span&gt;" vertex="1">
          <mxGeometry height="60" width="440" x="400" y="580" as="geometry" />
        </mxCell>
        <mxCell id="n6y0AcJ8ikb9XLiwta1j-59" parent="1" style="shape=note2;boundedLbl=1;whiteSpace=wrap;html=1;size=25;verticalAlign=top;align=left;spacingLeft=5;fontSize=12;" value="ESCRIBIR(&quot;{p.GetNombre()} está paralizado. Pierde su turno por completo.&quot;)&amp;nbsp;&lt;div&gt;p.DecrementarContadorParalisis()&amp;nbsp;&lt;/div&gt;&lt;div&gt;SI (p.GetContadorParalisis() &amp;lt;= 0)&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;ESCRIBIR(&quot;{p.GetNombre()} se ha recuperado de la parálisis.&quot;)&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;p.CambiarEstado(EstadoSaludable.ObtenerInstancia())&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;p.ResetearContadorParalisis()&lt;/div&gt;&lt;div&gt;FIN SI&lt;/div&gt;" vertex="1">
